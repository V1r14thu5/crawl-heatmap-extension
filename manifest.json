{
  "manifest_version": 3,
  "name": "Crawl Heatmap — Pass 1 vs Pass 2",
  "version": "1.1.0",
  "description": "Visualises which page elements are visible to Googlebot on the raw HTML pass vs the JS render pass. Supports Elementor, Divi, Beaver Builder, WPBakery, Bricks, and plain WordPress.",
  "author": "Nuno Lopes",
  "homepage_url": "https://github.com/your-username/crawl-heatmap-extension",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/heatmap.js"],
      "css": ["src/heatmap.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
